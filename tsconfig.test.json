			"@mariozechner/pi-tui": ["./tests/stubs/@mariozechner/pi-tui.ts"],
			"@sinclair/typebox/value": ["./tests/stubs/@sinclair/typebox/value.ts"],
			"@sinclair/typebox": ["./tests/stubs/@sinclair/typebox.ts"],
			"typebox": ["./tests/stubs/@sinclair/typebox.ts"]

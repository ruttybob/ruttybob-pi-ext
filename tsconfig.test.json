	"compilerOptions": {
		"target": "ES2022",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"paths": {
			"@mariozechner/pi-coding-agent": ["./tests/stubs/@mariozechner/pi-coding-agent.ts"],
